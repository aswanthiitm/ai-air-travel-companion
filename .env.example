# Optional: enables agent mode (LLM understanding + composed replies).
# Without any of these set, the deterministic fallback handles everything —
# all benchmarks and tests run fully offline. Set at most one provider.

# Groq (llama-3.3-70b-versatile)
GROQ_API_KEY=

# Cerebras (gpt-oss-120b, ~2-6s turns)
CEREBRAS_API_KEY=

# OpenRouter (default model: tencent/hy3:free)
OPENROUTER_API_KEY=

# Optional: override the default model for whichever provider key is set above
TWIN_LLM_MODEL=
